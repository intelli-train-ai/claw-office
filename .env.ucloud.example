# UCloud uhub registry credentials for scripts/build-and-push-ucloud.sh
# and scripts/deploy-ucloud.sh.
#
# Copy this file to .env.ucloud (gitignored by .env*) and fill in real values:
#   cp .env.ucloud.example .env.ucloud

REGISTRY=uhub.service.ucloud.cn
REGISTRY_USER=your-uhub-account@example.com
REGISTRY_PASS=your-uhub-password

# Optional overrides
# IMAGE_NAME=zrt-application/claw-office-o
# IMAGE_TAG=v0.0.1
